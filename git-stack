def cmd_export(args: List[str]) -> None:
    """Export stack configuration to JSON."""
    if has_help_flag(args):
        print_cmd_help("""\
Usage: git stack export [file]

Export all stack relationships to JSON format.
Writes to stdout by default, or to a file if specified.

Examples:
  git stack export                  # Print to stdout
  git stack export stacks.json     # Write to file
  git stack export -               # Explicit stdout""")

    relationships = get_all_stack_relationships()

    data = {
        "version": 1,
        "stacks": relationships
    }

    json_output = json.dumps(data, indent=2, sort_keys=True)

