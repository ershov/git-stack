def get_remote_tracking_branch(branch: str) -> Optional[str]:
    """Get the remote tracking branch for a local branch, if any."""
    code, stdout, _ = git('config', '--get', f'branch.{branch}.remote', check=False)
    if code != 0 or not stdout:
        return None
    remote = stdout
    code, stdout, _ = git('config', '--get', f'branch.{branch}.merge', check=False)
    if code != 0 or not stdout:
        return None
    # merge is like refs/heads/branch-name, extract the branch name
    merge_ref = stdout
    if merge_ref.startswith('refs/heads/'):
        merge_ref = merge_ref[len('refs/heads/'):]
    return f"{remote}/{merge_ref}"


