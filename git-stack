def has_help_flag(args: List[str]) -> bool:
    """Check if args contain -h or --help."""
    return '-h' in args or '--help' in args


def print_cmd_help(text: str) -> None:
    """Print command help text (dedented) and exit."""
    # Strip leading/trailing blank lines but keep indentation structure
    lines = text.strip().splitlines()
    print('\n'.join(lines))
    sys.exit(0)


# ============================================================================
# Git Helper Functions
# ============================================================================

def git(*args: str, check: bool = True, capture: bool = True) -> Tuple[int, str, str]:
    """Run a git command and return (returncode, stdout, stderr)."""
    cmd = ['git'] + list(args)
    result = subprocess.run(
        cmd,
        capture_output=capture,
        text=True,
    )
    if check and result.returncode != 0:
        if capture:
            sys.stderr.write(result.stderr)
        raise SystemExit(result.returncode)
    return result.returncode, result.stdout.strip(), result.stderr.strip()


def git_output(*args: str, check: bool = True) -> str:
    """Run a git command and return stdout."""
    _, stdout, _ = git(*args, check=check)
    return stdout


def git_run(*args: str) -> int:
    """Run a git command with output to terminal, return exit code."""
    result = subprocess.run(['git'] + list(args))
    return result.returncode


def get_git_root() -> Path:
    """Get the root directory of the git repository."""
    return Path(git_output('rev-parse', '--show-toplevel'))


def get_current_branch() -> str:
    """Get the name of the current branch."""
    return git_output('rev-parse', '--abbrev-ref', 'HEAD')


def is_rebase_in_progress(git_root: Path) -> bool:
    """Check if a rebase is currently in progress."""
    return (git_root / '.git' / 'rebase-merge').is_dir() or \
           (git_root / '.git' / 'rebase-apply').is_dir()


# ============================================================================
# Stack Base Management (git config)
# ============================================================================

def get_stack_base(branch: Optional[str] = None) -> Optional[str]:
    """Get the stack base for a branch."""
    if branch is None:
        branch = get_current_branch()
    code, stdout, _ = git('config', '--get', f'branch.{branch}.stackbase', check=False)
    return stdout if code == 0 and stdout else None


def set_stack_base(branch: str, base: str) -> None:
    """Set the stack base for a branch."""
    git('config', f'branch.{branch}.stackbase', base)


def remove_stack_base(branch: str) -> None:
    """Remove the stack base for a branch."""
    git('config', '--unset', f'branch.{branch}.stackbase', check=False)


def get_all_stack_relationships() -> Dict[str, str]:
    """Get all branch -> base relationships."""
    code, stdout, _ = git('config', '--get-regexp', r'^branch\..*\.stackbase$', check=False)
    if code != 0 or not stdout:
        return {}

    relationships = {}
    for line in stdout.splitlines():
        # Format: branch.<name>.stackbase <base>
        match = re.match(r'^branch\.(.+)\.stackbase\s+(.+)$', line)
        if match:
            branch, base = match.groups()
            relationships[branch] = base
    return relationships


def get_all_stacked_branches() -> List[str]:
    """Get list of all stacked branches."""
    return list(get_all_stack_relationships().keys())


def get_dependents(base: str) -> List[str]:
    """Get all branches that depend on the given base."""
    relationships = get_all_stack_relationships()
    return [branch for branch, b in relationships.items() if b == base]


def find_cycle(relationships: Dict[str, str], start: str) -> Optional[List[str]]:
    """
    Detect a cycle starting from 'start' in the given relationships.
    Returns the cycle as a list [a, b, ..., a] if found, or None.
    """
    visited = []
    current = start
    seen = set()
    while current in relationships:
        if current in seen:
            # Found a cycle - extract it
            cycle_start = visited.index(current)
            return visited[cycle_start:] + [current]
        seen.add(current)
        visited.append(current)
        current = relationships[current]
    return None


def find_all_cycles(relationships: Dict[str, str]) -> List[List[str]]:
    """
    Find all unique cycles in the given relationships.
    Returns a list of cycles, each cycle is [a, b, ..., a].
    """
    reported = set()  # frozensets of cycle members to avoid duplicates
    cycles = []
    for branch in relationships:
        cycle = find_cycle(relationships, branch)
        if cycle:
            members = frozenset(cycle[:-1])
            if members not in reported:
                reported.add(members)
                cycles.append(cycle)
    return cycles


def check_no_cycles(relationships: Optional[Dict[str, str]] = None) -> None:
    """
    Check for circular dependencies and exit with an error if any are found.
    Call this before any operation that traverses the dependency graph.
    """
    if relationships is None:
        relationships = get_all_stack_relationships()
    cycles = find_all_cycles(relationships)
    if cycles:
        print_cycles(cycles)
        sys.exit(1)


def print_cycles(cycles: List[List[str]]) -> None:
    """Print a human-readable error message about circular dependencies."""
    print("Error: Circular dependencies detected!")
    print()
    for cycle in cycles:
        print(f"  {' -> '.join(cycle)}")
    print()
    print("Fix with:")
    print("  git stack set-parent <branch> -          # Detach a branch to break the cycle")
    print("  git stack set-parent <branch> <new-parent>")


# ============================================================================
# Topological Sort for Dependency Order
# ============================================================================

def get_branches_in_dependency_order(target_branch: Optional[str] = None) -> List[str]:
    """
    Get all stacked branches in topological order (dependencies first).
    If target_branch is specified, only return ancestors of that branch (including itself).
    Exits with error if circular dependencies are detected.
    """
    relationships = get_all_stack_relationships()
    if not relationships:
        return []

    # Refuse to work if there are cycles
    check_no_cycles(relationships)

    # Build parent and children maps
    parent = relationships  # child -> parent
    children: Dict[str, List[str]] = defaultdict(list)
    for child, par in parent.items():
        children[par].append(child)

    # If target specified, find all ancestors
    ancestors = set()
    if target_branch:
        current = target_branch
        while current in parent:
            ancestors.add(current)
            current = parent[current]

    # Topological sort using Kahn's algorithm
    all_branches = list(parent.keys())

    # Calculate in-degree (only count edges within stacked branches)
    in_degree: Dict[str, int] = defaultdict(int)
    for branch in all_branches:
        base = parent[branch]
        if base in parent:
            # base is also a stacked branch, so this edge counts
            in_degree[branch] += 1

    # Find branches with no stacked dependencies
    queue = sorted([b for b in all_branches if in_degree[b] == 0])

    result = []
    while queue:
        branch = queue.pop(0)

        # Add to result if no target or if it's an ancestor of target
        if not target_branch or branch in ancestors:
            result.append(branch)

        # Decrease in-degree of children
        for child in sorted(children.get(branch, [])):
            in_degree[child] -= 1
            if in_degree[child] == 0:
                queue.append(child)
        queue.sort()  # Keep deterministic order

    return result


def get_descendants_in_dependency_order(root_branch: str) -> List[str]:
    """
    Get all stacked branches that are descendants of root_branch
    (i.e. have root_branch somewhere in their ancestry chain),
    in topological order (parents before children), NOT including root_branch itself.
    Exits with error if circular dependencies are detected.
    """
    relationships = get_all_stack_relationships()
    if not relationships:
        return []

    check_no_cycles(relationships)

    # Build children map
    children: Dict[str, List[str]] = defaultdict(list)
    for child, par in relationships.items():
        children[par].append(child)

    # BFS/DFS from root_branch collecting all descendants in topo order
    result: List[str] = []
    queue = sorted(children.get(root_branch, []))
    visited: set = set()
    while queue:
        branch = queue.pop(0)
        if branch in visited:
            continue
        visited.add(branch)
        result.append(branch)
        for child in sorted(children.get(branch, [])):
            if child not in visited:
                queue.append(child)
        queue.sort()

    return result


# ============================================================================
# Sync State Management
# ============================================================================

class SyncState:
    """Manages the state of an in-progress sync operation."""

    def __init__(self, git_root: Path):
        self.state_dir = git_root / '.git' / 'stack-sync-state'

    def in_progress(self) -> bool:
        """Check if a sync is in progress."""
        return self.state_dir.is_dir()

    def init(self, original_branch: str, branches: List[str], new_base: Optional[str] = None) -> None:
        """Initialize sync state."""
        self.state_dir.mkdir(parents=True, exist_ok=True)

        (self.state_dir / 'original_branch').write_text(original_branch)
        (self.state_dir / 'branches_to_sync').write_text('\n'.join(branches))
        (self.state_dir / 'branches_completed').write_text('')

        # Save new_base for rebase command (optional)
        if new_base:
            (self.state_dir / 'new_base').write_text(new_base)

        # Save original refs for abort-all
        refs = []
        for branch in branches:
            ref = git_output('rev-parse', branch)
            refs.append(f'{branch} {ref}')
        (self.state_dir / 'original_refs').write_text('\n'.join(refs))

    def get_branches_to_sync(self) -> List[str]:
        """Get all branches that need to be synced."""
        path = self.state_dir / 'branches_to_sync'
        if not path.exists():
            return []
        return [b for b in path.read_text().splitlines() if b]

    def get_completed_branches(self) -> List[str]:
        """Get branches that have been completed."""
        path = self.state_dir / 'branches_completed'
        if not path.exists():
            return []
        return [b for b in path.read_text().splitlines() if b]

    def get_remaining_branches(self) -> List[str]:
        """Get branches that still need to be synced."""
        to_sync = self.get_branches_to_sync()
        completed = set(self.get_completed_branches())
        return [b for b in to_sync if b not in completed]

    def get_current_sync_branch(self) -> Optional[str]:
        """Get the first remaining branch."""
        remaining = self.get_remaining_branches()
        return remaining[0] if remaining else None

    def mark_completed(self, branch: str) -> None:
        """Mark a branch as completed."""
        path = self.state_dir / 'branches_completed'
        with open(path, 'a') as f:
            f.write(branch + '\n')

    def get_original_branch(self) -> Optional[str]:
        """Get the original branch before sync started."""
        path = self.state_dir / 'original_branch'
        if not path.exists():
            return None
        return path.read_text().strip()

    def get_new_base(self) -> Optional[str]:
        """Get the new base for rebase operation (if any)."""
        path = self.state_dir / 'new_base'
        if not path.exists():
            return None
        return path.read_text().strip()

    def get_original_refs(self) -> Dict[str, str]:
        """Get original refs for all branches."""
        path = self.state_dir / 'original_refs'
        if not path.exists():
            return {}
        refs = {}
        for line in path.read_text().splitlines():
            if ' ' in line:
                branch, ref = line.split(' ', 1)
                refs[branch] = ref
        return refs

    def restore_original_refs(self) -> None:
        """Restore all branches to their original refs."""
        for branch, ref in self.get_original_refs().items():
            print(f"Restoring '{branch}' to {ref}...")
            git('checkout', branch, check=False)
            git('reset', '--hard', ref)

    def cleanup(self) -> None:
        """Remove sync state."""
        if self.state_dir.exists():
            shutil.rmtree(self.state_dir)


def check_no_sync_in_progress(state: SyncState) -> None:
    """Check that no sync is in progress, exit with error if one is."""
    if state.in_progress():
        print("Error: A sync operation is in progress.")
        print()
        print("Use one of the following commands:")
        print("  git stack continue      - Continue the sync after resolving conflicts")
        print("  git stack abort         - Abort the current rebase and continue with remaining branches")
        print("  git stack abort-all     - Abort and restore all branches to their original state")
        print()
        print("Remaining branches to sync:")
        for branch in state.get_remaining_branches():
            print(f"  {branch}")
        sys.exit(1)


def sync_single_branch(branch: str, state: SyncState, git_root: Path) -> bool:
    """
    Sync a single branch onto its base.
    Returns True on success, False on failure.
    """
    base = get_stack_base(branch)
    if not base:
        print(f"Error: '{branch}' has no stack base")
        return False

    print(f"Syncing '{branch}' onto '{base}'...")
    git('checkout', branch)

    fork_point = git_output('merge-base', branch, base)

    code = git_run('rebase', '--onto', base, fork_point, branch)
    if code == 0:
        state.mark_completed(branch)
        return True
    else:
        if is_rebase_in_progress(git_root):
            # Rebase stopped mid-way due to conflicts.
            print()
            print(f"Rebase failed for '{branch}'. Resolve conflicts and then run:")
            print("  git stack continue      - Continue after resolving conflicts")
            print("  git stack abort         - Abort this rebase and skip to next branch")
            print("  git stack abort-all     - Abort and restore all branches")
        elif not state.get_completed_branches():
            # Failed immediately, nothing was changed – clean up state.
            state.cleanup()
            print()
            print(f"Rebase failed for '{branch}'.")
        else:
            # Rebase tool itself errored after partial progress (no conflict to
            # resolve).  State is preserved so the user can inspect and recover.
            print()
            print(f"Rebase failed for '{branch}' (no conflict state left).")
            print("If you have manually fixed the situation, run:")
            print("  git stack rebase-reset  - Clear state without restoring branches")
            print("  git stack abort-all     - Abort and restore all branches")
        return False


def rebase_onto_new_base(branch: str, new_base: str, old_base: Optional[str], state: SyncState, git_root: Path) -> bool:
    """
    Rebase a branch onto a new base (different from its stack base).
    If old_base is None, uses merge-base with new_base as fork point.
    Returns True on success, False on failure.
    """
    print(f"Rebasing '{branch}' onto '{new_base}'...")
    git('checkout', branch)

    # Determine fork point
    if old_base:
        fork_point = git_output('merge-base', branch, old_base)
    else:
        fork_point = git_output('merge-base', branch, new_base)

    code = git_run('rebase', '--onto', new_base, fork_point, branch)
    if code == 0:
        set_stack_base(branch, new_base)
        state.mark_completed(branch)
        return True
    else:
        if is_rebase_in_progress(git_root):
            print()
            print(f"Rebase failed for '{branch}'. Resolve conflicts and then run:")
            print("  git stack continue      - Continue after resolving conflicts")
            print("  git stack abort         - Abort this rebase and restore original state")
            print("  git stack abort-all     - Abort and restore all branches")
        elif not state.get_completed_branches():
            state.cleanup()
            print()
            print(f"Rebase failed for '{branch}'.")
        else:
            print()
            print(f"Rebase failed for '{branch}' (no conflict state left).")
            print("If you have manually fixed the situation, run:")
            print("  git stack rebase-reset  - Clear state without restoring branches")
            print("  git stack abort-all     - Abort and restore all branches")
        return False


# ============================================================================
# Tree Display for `ls` command
# ============================================================================

def get_commits_ahead(branch: str, base: str) -> int:
    """Get number of commits branch is ahead of base."""
    code, stdout, _ = git('rev-list', '--count', f'{base}..{branch}', check=False)
    if code == 0 and stdout:
        try:
            return int(stdout)
        except ValueError:
            pass
    return 0


def get_sync_status(branch: str, base: str) -> str:
    """Check if branch is synced with base."""
    merge_base = git_output('merge-base', branch, base, check=False)
    base_head = git_output('rev-parse', base, check=False)
    return "synced" if merge_base == base_head else "needs sync"


def get_remote_status(branch: str) -> Optional[Tuple[str, str]]:
    """
    Get remote tracking status for a branch.
    Returns (upstream_name, status_string) or None if no upstream.
    """
    # Get the upstream tracking branch
    code, upstream, _ = git('rev-parse', '--abbrev-ref', f'{branch}@{{upstream}}', check=False)
    if code != 0 or not upstream:
        return None

    # Get ahead/behind counts
    code, stdout, _ = git('rev-list', '--left-right', '--count', f'{branch}...{upstream}', check=False)
    if code != 0 or not stdout:
        return (upstream, "?")

    parts = stdout.split()
    if len(parts) != 2:
        return (upstream, "?")

    ahead, behind = int(parts[0]), int(parts[1])

    if ahead == 0 and behind == 0:
        return (upstream, "")
    elif ahead > 0 and behind == 0:
        return (upstream, f"{ahead} ahead")
    elif ahead == 0 and behind > 0:
        return (upstream, f"{behind} behind")
    else:
        return (upstream, f"{ahead} ahead, {behind} behind")


def print_tree(state: Optional[SyncState] = None) -> None:
    """Print stacked branches as a tree."""
    relationships = get_all_stack_relationships()
    if not relationships:
        print("No stacked branches found.")
        return

    # Detect circular dependencies
    cycles = find_all_cycles(relationships)
    if cycles:
        print_cycles(cycles)
        print()
        # Still try to display what we can, excluding cycle members
        cycle_members = set()
        for cycle in cycles:
            cycle_members.update(cycle[:-1])
        # Remove cycle members from relationships for display
        clean_relationships = {b: p for b, p in relationships.items() if b not in cycle_members}
        if not clean_relationships:
            return
        print("Non-circular branches:")
        relationships = clean_relationships

    current_branch = get_current_branch()

    # Get sync state info if available
    sync_in_progress = state and state.in_progress()
    completed_branches = set(state.get_completed_branches()) if sync_in_progress else set()
    remaining_branches = state.get_remaining_branches() if sync_in_progress else []
    current_sync_branch = remaining_branches[0] if remaining_branches else None

    # Show sync status header if in progress
    if sync_in_progress:
        new_base = state.get_new_base()
        if new_base:
            print(f"[Rebase onto '{new_base}' in progress]")
        else:
            print("[Sync in progress]")
        print()

    # Build children map
    children: Dict[str, List[str]] = defaultdict(list)
    all_bases = set()
    for branch, base in relationships.items():
        children[base].append(branch)
        all_bases.add(base)

    # Find roots (bases that are not stacked themselves)
    roots = sorted([base for base in all_bases if base not in relationships])

    def print_branch(branch: str, prefix: str, is_last: bool, is_root: bool) -> None:
        connector = "" if is_root else ("└── " if is_last else "├── ")
        # marker = "* " if branch == current_branch else "· "
        marker = "* " if branch == current_branch else "  "

        # Get status info
        status_parts = []

        # Add sync operation status if in progress
        if sync_in_progress:
            if branch == current_sync_branch:
                status_parts.append("REBASING")
            elif branch in completed_branches:
                status_parts.append("done")
            elif branch in remaining_branches:
                status_parts.append("pending")

        if branch in relationships:
            base = relationships[branch]
            ahead = get_commits_ahead(branch, base)
            sync = get_sync_status(branch, base)
            status_parts.append(f"{ahead} ahead")
            if sync == "needs sync":
                status_parts.append(sync)

        # Get remote tracking status
        remote_info = get_remote_status(branch)
        if remote_info:
            upstream, remote_status = remote_info
            status_parts.append(f"{upstream} {remote_status}")

        status = f" ({', '.join(status_parts)})" if status_parts else ""

        print(f"{marker}{prefix}{connector}{branch}{status}")

        kids = sorted(children.get(branch, []))
        new_prefix = "" if is_root else prefix + ("    " if is_last else "│   ")

        for i, kid in enumerate(kids):
            print_branch(kid, new_prefix, i == len(kids) - 1, False)

    for root in roots:
        print_branch(root, "", True, True)


