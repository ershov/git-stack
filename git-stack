def cmd_ls(state: SyncState) -> None:
    """List stacked branches as a tree."""
    print_tree(state)


def cmd_create(args: List[str]) -> None:
    """Create a new stacked branch."""
    if not args:
        print("Error: Branch name required")
        print("Usage: git stack create <branch>")
        sys.exit(1)

    new_branch = args[0]
    current = get_current_branch()

    git('checkout', '-b', new_branch)
    set_stack_base(new_branch, current)
    print(f"Created stacked branch '{new_branch}' based on '{current}'")


def _set_branch_parent(branch: str, parent: str, action: str = "set parent") -> None:
    """
    Helper to set the parent/base of a branch with validation.

    Args:
        branch: The branch to modify (will be resolved if '.')
        parent: The parent/base branch to set
        action: Description for error/success messages ("adopt" or "set parent")
    """
    current = get_current_branch()

    if branch == '.':
        branch = current

    # Validate that branch exists
    code, _, _ = git('rev-parse', '--verify', branch, check=False)
    if code != 0:
        print(f"Error: Branch '{branch}' does not exist")
        sys.exit(1)

    # Validate that parent exists
    code, _, _ = git('rev-parse', '--verify', parent, check=False)
    if code != 0:
        print(f"Error: Parent branch '{parent}' does not exist")
        sys.exit(1)

    # Prevent self-reference
    if branch == parent:
        print(f"Error: Cannot {action} a branch onto itself")
        sys.exit(1)

    old_parent = get_stack_base(branch)
    set_stack_base(branch, parent)

    if old_parent:
        print(f"Changed parent of '{branch}' from '{old_parent}' to '{parent}'")
    else:
        print(f"Set parent of '{branch}' to '{parent}'")


