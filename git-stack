def _set_branch_parent(branch: str, parent: str, action: str = "set parent", force: bool = False) -> None:
    """
    Helper to set the parent/base of a branch with validation.

    Args:
        branch: The branch to modify (will be resolved if '.')
        parent: The parent/base branch to set, or '-' to detach
        action: Description for error/success messages ("adopt" or "set parent")
        force: If True, break circular dependencies instead of erroring
    """
    current = get_current_branch()

    if branch == '.':
        branch = current

    # Handle detach
    if parent == '-':
        old_parent = get_stack_base(branch)
        if not old_parent:
            print(f"'{branch}' is not stacked, nothing to detach")
            return
        remove_stack_base(branch)
        print(f"Detached '{branch}' from '{old_parent}'")
        return

    # Validate that branch exists
    code, _, _ = git('rev-parse', '--verify', branch, check=False)
    if code != 0:
        print(f"Error: Branch '{branch}' does not exist")
        sys.exit(1)

    # Validate that parent exists
    code, _, _ = git('rev-parse', '--verify', parent, check=False)
    if code != 0:
        print(f"Error: Parent branch '{parent}' does not exist")
        sys.exit(1)

    # Prevent self-reference
    if branch == parent:
        print(f"Error: Cannot {action} a branch onto itself")
        sys.exit(1)

    # Check for circular dependency
    # Simulate what the relationships would look like after this change
    relationships = get_all_stack_relationships()
    relationships[branch] = parent
    cycle = find_cycle(relationships, branch)
    if cycle:
        if force:
            # Break the cycle: detach the branch that would close the loop
            # The cycle is [a, b, ..., x, a]. We break the last link before
            # it loops back, i.e. remove the stackbase of the branch just
            # before 'branch' in the cycle.
            # cycle[-2] -> cycle[-1](==branch) -> parent -> ... -> cycle[-2]
            # We detach cycle[-2] from its parent.
            break_branch = cycle[-2]
            break_old_parent = get_stack_base(break_branch)
            remove_stack_base(break_branch)
            print(f"Warning: Breaking circular dependency by detaching '{break_branch}' from '{break_old_parent}'")
        else:
            print(f"Error: Circular dependency detected:")
            print(f"  {' -> '.join(cycle)}")
            print()
            print("To fix this:")
            print(f"  git stack set-parent <branch> -     # Detach a branch to break the cycle")
            print(f"  git stack {action} -f ...            # Force: auto-break the cycle")
            sys.exit(1)

    old_parent = get_stack_base(branch)
    set_stack_base(branch, parent)

    if old_parent:
        print(f"Changed parent of '{branch}' from '{old_parent}' to '{parent}'")
    else:
        print(f"Set parent of '{branch}' to '{parent}'")


