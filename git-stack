def cmd_import(args: List[str], update: bool = False) -> None:
    """Import stack configuration from JSON."""
    if has_help_flag(args):
        if update:
            print_cmd_help("""\
Usage: git stack import-update <file>

Import stack configuration from JSON, merging with existing
configuration. Existing relationships are preserved; new ones
are added or updated.

Use '-' to read from stdin.""")
        else:
            print_cmd_help("""\
Usage: git stack import <file>

Import stack configuration from JSON, replacing all existing
configuration. All current stack relationships are removed first.

Use '-' to read from stdin.

See also: git stack import-update (merge instead of replace)""")

    if not args:
        print("Error: File path required (use '-' for stdin)")
        print("Usage: git stack import <file>")
        print("       git stack import-update <file>")
        sys.exit(1)

    filepath = args[0]

    # Read JSON input
    if filepath == '-':
        json_input = sys.stdin.read()
    else:
        if not os.path.exists(filepath):
            print(f"Error: File '{filepath}' not found")
            sys.exit(1)
        with open(filepath, 'r') as f:
            json_input = f.read()

    try:
        data = json.loads(json_input)
    except json.JSONDecodeError as e:
        print(f"Error: Invalid JSON: {e}")
        sys.exit(1)

    # Validate structure
    if not isinstance(data, dict):
        print("Error: JSON must be an object")
        sys.exit(1)

    if 'stacks' not in data:
        print("Error: JSON must contain 'stacks' key")
        sys.exit(1)

    stacks = data['stacks']
    if not isinstance(stacks, dict):
        print("Error: 'stacks' must be an object mapping branch -> base")
        sys.exit(1)

    # If not updating, clear existing configuration first
    if not update:
        existing = get_all_stack_relationships()
        for branch in existing:
            remove_stack_base(branch)

    # Import new relationships
    imported_count = 0
    for branch, base in stacks.items():
        if not isinstance(branch, str) or not isinstance(base, str):
            print(f"Warning: Skipping invalid entry: {branch} -> {base}")
            continue
        set_stack_base(branch, base)
        imported_count += 1

    action = "Updated" if update else "Imported"
    source = "stdin" if filepath == '-' else f"'{filepath}'"
    print(f"{action} {imported_count} stack relationship(s) from {source}")


def cmd_zap(args: List[str], git_root: Path, state: SyncState) -> None:
    """Remove all stack configuration from the repository."""
    if has_help_flag(args):
        print_cmd_help("""\
Usage: git stack zap

Remove ALL stack configuration from the repository.
This includes all branch relationships and any in-progress
sync/rebase state. Prompts for confirmation before proceeding.

The git branches themselves are NOT deleted.""")

    relationships = get_all_stack_relationships()
    has_sync_state = state.in_progress()

    if not relationships and not has_sync_state:
        print("No stack configuration to remove.")
        return

    # Confirm before deleting
    if relationships:
        print(f"This will remove {len(relationships)} stack relationship(s):")
        for branch, base in sorted(relationships.items()):
            print(f"  {branch} -> {base}")

    if has_sync_state:
        if relationships:
            print()
        print("This will also clear the in-progress sync/rebase state.")

    print()
    response = input("Are you sure? [y/N] ")
    if response.lower() not in ('y', 'yes'):
        print("Aborted.")
        sys.exit(1)

    # Clear sync state if present
    if has_sync_state:
        # Abort any in-progress rebase first
        # if is_rebase_in_progress(git_root):
        #     print("Aborting current rebase...")
        #     git('rebase', '--abort', check=False)
        state.cleanup()
        print("Cleared sync/rebase state.")

    # Remove stack relationships
    if relationships:
        for branch in relationships:
            remove_stack_base(branch)
        print(f"Removed {len(relationships)} stack relationship(s).")


# ============================================================================
# Main Entry Point
# ============================================================================

def main() -> None:
    args = sys.argv[1:]
    command = args[0] if args else 'ls'
    cmd_args = args[1:] if len(args) > 1 else []

    # Commands that don't need git context
    if command in ('h', 'help', '-h', '--help'):
        cmd_help()
        return

    # Get git context
    try:
        git_root = get_git_root()
    except SystemExit:
        print("Error: Not in a git repository")
        sys.exit(1)

    state = SyncState(git_root)

    # Dispatch commands
    if command in ('ls', 'list', 'st', 'status'):
        cmd_ls(cmd_args, state)
    elif command in ('cr', 'create'):
        cmd_create(cmd_args)
    elif command in ('ad', 'adopt'):
        cmd_adopt(cmd_args)
    elif command in ('sp', 'set-parent', 'set_parent', 'sb', 'set-base', 'set_base'):
        cmd_set_parent(cmd_args)
    elif command in ('b', 'base'):
        cmd_base(cmd_args)
    elif command in ('s1', 'sync1'):
        cmd_sync1(cmd_args, git_root, state)
    elif command in ('su', 'sync-up', 'sync_up'):
        cmd_sync(cmd_args, git_root, state)
    elif command in ('sd', 'sync-deps', 'sync_deps'):
        cmd_sync_deps(cmd_args, git_root, state)
    elif command in ('sa', 'sync-all', 'sync_all'):
        cmd_sync_all(cmd_args, git_root, state)
    elif command in ('c', 'continue'):
        cmd_continue(cmd_args, git_root, state)
    elif command in ('ab', 'abort'):
        cmd_abort(cmd_args, git_root, state)
    elif command in ('aa', 'abort-all', 'abort_all'):
        cmd_abort_all(cmd_args, git_root, state)
    elif command in ('rr', 'rebase-reset', 'rebase_reset'):
        cmd_rebase_reset(cmd_args, git_root, state)
    elif command in ('p', 'push'):
        cmd_push(cmd_args)
    elif command in ('pa', 'push-all', 'push_all'):
        cmd_push_all(cmd_args)
    elif command in ('pr', 'push-remotes', 'push_remotes'):
        cmd_push_remotes(cmd_args)
    elif command in ('d', 'delete'):
        cmd_delete(cmd_args)
    elif command in ('rn', 'rename'):
        cmd_rename(cmd_args)
    elif command in ('spl', 'split'):
        cmd_split(cmd_args)
    elif command in ('rb', 'rebase'):
        cmd_rebase(cmd_args, git_root, state)
    elif command in ('l', 'log'):
        cmd_log(cmd_args)
    elif command in ('df', 'diff'):
        cmd_diff(cmd_args)
    elif command == 'export':
        cmd_export(cmd_args)
    elif command == 'import':
        cmd_import(cmd_args, update=False)
    elif command in ('import-update', 'import_update'):
        cmd_import(cmd_args, update=True)
    elif command == 'zap':
        cmd_zap(cmd_args, git_root, state)
    else:
        print(f"Unknown subcommand: {command}")
        cmd_help()
        sys.exit(1)


if __name__ == '__main__':
    main()
