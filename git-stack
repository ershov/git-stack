def main() -> None:
    args = sys.argv[1:]
    command = args[0] if args else 'ls'
    cmd_args = args[1:] if len(args) > 1 else []

    # Commands that don't need git context
    if command in ('h', 'help', '-h', '--help'):
        cmd_help()
        return

    # Get git context
    try:
        git_root = get_git_root()
    except SystemExit:
        print("Error: Not in a git repository")
        sys.exit(1)

    state = SyncState(git_root)

    # Dispatch commands
    if command in ('ls', 'list', 'st', 'status'):
        cmd_ls(state)
    elif command in ('cr', 'create'):
