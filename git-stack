    code, _, _ = git('rev-parse', '--verify', old_name, check=False)
    if code != 0:
        print(f"Error: Branch '{old_name}' does not exist")
        sys.exit(1)

    # Check if new branch already exists
    code, _, _ = git('rev-parse', '--verify', new_name, check=False)
    if code == 0:
        print(f"Error: Branch '{new_name}' already exists")
        sys.exit(1)

    # Get the stack base of the old branch (if any)
    old_base = get_stack_base(old_name)

    # Get all branches that depend on the old branch
    dependents = get_dependents(old_name)

    # Rename the git branch
    git('branch', '-m', old_name, new_name)
    print(f"Renamed branch '{old_name}' to '{new_name}'")

    # Update stack base for the renamed branch (if it was stacked)
    if old_base:
        # Remove old config and set new one
        remove_stack_base(old_name)
        set_stack_base(new_name, old_base)
        print(f"  Updated stack base: '{new_name}' -> '{old_base}'")

    # Update all dependents to point to the new name
    for dep in dependents:
        set_stack_base(dep, new_name)
        print(f"  Updated dependent: '{dep}' -> '{new_name}'")

    # If we were on the old branch, we're now on the new one
    if current == old_name:
        print(f"Now on branch '{new_name}'")


def _split_auto_detect() -> Tuple[str, str]:
    """
    Auto-detect parent and child branches for split command.
    Returns (parent, child) tuple.
    Exits with error if detection fails or is ambiguous.
    """
    current_commit = git_output('rev-parse', 'HEAD')

    # Find which stacked branches contain this commit
    relationships = get_all_stack_relationships()

    # Find potential parents: stacked branches whose tip is an ancestor of current commit
    # or non-stacked bases that are ancestors
    potential_parents = []
    for branch, base in relationships.items():
        # Check if branch tip is ancestor of or equal to current commit
        branch_commit = git_output('rev-parse', branch, check=False)
        if branch_commit == current_commit:
            # Current commit is the tip of this branch - can't split
            continue
        # Check if branch is an ancestor of current commit
        code, _, _ = git('merge-base', '--is-ancestor', branch, current_commit, check=False)
        if code == 0:
            potential_parents.append(branch)

    # Also check non-stacked bases
    all_bases = set(relationships.values())
    for base in all_bases:
        if base not in relationships:  # Non-stacked base
            code, _, _ = git('merge-base', '--is-ancestor', base, current_commit, check=False)
            if code == 0:
                potential_parents.append(base)

    # Filter to find the closest parent (the one that is not an ancestor of any other potential parent)
    closest_parents = []
    for p in potential_parents:
        is_closest = True
        for other in potential_parents:
            if p != other:
                # Check if 'other' is a descendant of 'p' (p is ancestor of other)
                code, _, _ = git('merge-base', '--is-ancestor', p, other, check=False)
                if code == 0:
                    # p is ancestor of other, so other is closer
                    is_closest = False
                    break
        if is_closest:
            closest_parents.append(p)

    if not closest_parents:
        print("Error: Cannot determine parent branch for current commit")
        print("Use explicit form: git stack split <new-branch> <parent> <child>")
        sys.exit(1)

    if len(closest_parents) > 1:
        print("Error: Ambiguous parent - multiple potential parents found:")
        for p in closest_parents:
            print(f"  {p}")
        print()
        print("Use explicit form: git stack split <new-branch> <parent> <child>")
        sys.exit(1)

    parent = closest_parents[0]

    # Find potential children: branches that have current commit as ancestor
    # and whose base is the detected parent
    potential_children = []
    for branch, base in relationships.items():
        # Check if current commit is ancestor of branch
        code, _, _ = git('merge-base', '--is-ancestor', current_commit, branch, check=False)
        if code == 0:
            # Current commit is ancestor of this branch
            # Check if the branch's base is our detected parent
            if base == parent:
                potential_children.append(branch)

    if not potential_children:
        print("Error: Cannot determine child branch for current commit")
        print("No stacked branch found that is based on the detected parent and contains this commit")
        print()
        print("Use explicit form: git stack split <new-branch> <parent> <child>")
        sys.exit(1)

    if len(potential_children) > 1:
        print("Error: Ambiguous child - multiple potential children found:")
        for c in potential_children:
            print(f"  {c}")
        print()
        print("Use explicit form: git stack split <new-branch> <parent> <child>")
        sys.exit(1)

    child = potential_children[0]
    return parent, child


def _split_validate_explicit(parent: str, child: str) -> None:
    """
    Validate explicit parent and child arguments for split command.
    Exits with error if validation fails.
    """
    # Validate parent exists
    code, _, _ = git('rev-parse', '--verify', parent, check=False)
    if code != 0:
        print(f"Error: Parent branch '{parent}' does not exist")
        sys.exit(1)

    # Validate child exists
    code, _, _ = git('rev-parse', '--verify', child, check=False)
    if code != 0:
        print(f"Error: Child branch '{child}' does not exist")
        sys.exit(1)

    # Validate child is stacked on parent
    child_base = get_stack_base(child)
    if child_base != parent:
        print(f"Error: '{child}' is not stacked on '{parent}'")
        if child_base:
            print(f"  '{child}' is stacked on '{child_base}'")
        else:
            print(f"  '{child}' is not a stacked branch")
        sys.exit(1)


def cmd_split(args: List[str]) -> None:
    """Split a commit into a new stacked branch between parent and child."""
    if not args:
        print("Error: Branch name required")
        print("Usage: git stack split <new-branch>                    # Auto-detect parent/child")
        print("       git stack split <new-branch> <parent> <child>   # Explicit parent/child")
        sys.exit(1)

    new_branch = args[0]

    # Check if new branch already exists
    code, _, _ = git('rev-parse', '--verify', new_branch, check=False)
    if code == 0:
        print(f"Error: Branch '{new_branch}' already exists")
        sys.exit(1)

    if len(args) == 1:
        # Auto-detect mode
        parent, child = _split_auto_detect()
    elif len(args) == 3:
        # Explicit mode
        parent = args[1]
        child = args[2]
        _split_validate_explicit(parent, child)
    else:
        print("Error: Invalid number of arguments")
        print("Usage: git stack split <new-branch>                    # Auto-detect parent/child")
        print("       git stack split <new-branch> <parent> <child>   # Explicit parent/child")
        sys.exit(1)

    # Get current commit to create the new branch at
    current_commit = git_output('rev-parse', 'HEAD')

    # Validate that current commit is between parent and child
    # 1. Current commit must be descendant of parent (or equal)
    code, _, _ = git('merge-base', '--is-ancestor', parent, current_commit, check=False)
    if code != 0:
        print(f"Error: Current commit is not a descendant of '{parent}'")
        sys.exit(1)

    # 2. Current commit must be ancestor of child (or equal)
    code, _, _ = git('merge-base', '--is-ancestor', current_commit, child, check=False)
    if code != 0:
        print(f"Error: Current commit is not an ancestor of '{child}'")
        sys.exit(1)

    # 3. Current commit must not be equal to parent tip
    parent_commit = git_output('rev-parse', parent)
    if current_commit == parent_commit:
        print(f"Error: Current commit is the tip of '{parent}', nothing to split")
        sys.exit(1)

    # Create the new branch at current commit
    git('branch', new_branch, current_commit)

    # Set up stack relationships:
    # new_branch is stacked on parent
    set_stack_base(new_branch, parent)

    # child is now stacked on new_branch
    set_stack_base(child, new_branch)

    print(f"Created stacked branch '{new_branch}' at current commit")
    print(f"  {parent} <- {new_branch} <- {child}")
    print()
    print(f"Stack relationships updated:")
    print(f"  '{new_branch}' is now stacked on '{parent}'")
    print(f"  '{child}' is now stacked on '{new_branch}'")


