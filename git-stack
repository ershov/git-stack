def cmd_continue(git_root: Path, state: SyncState) -> None:
    """Continue sync after resolving conflicts."""
    if not state.in_progress():
        print("No sync operation in progress.")
        sys.exit(1)

    # Check if this is a rebase-onto-new-base operation
    new_base = state.get_new_base()

    # First, try to continue any in-progress rebase
    if is_rebase_in_progress(git_root):
        print("Continuing rebase...")
        code = git_run('rebase', '--continue')
        if code != 0:
            print()
            print("Rebase still has conflicts. Resolve them and run 'git stack continue' again.")
            sys.exit(1)

        # Mark current branch as completed
        current_sync = state.get_current_sync_branch()
        if current_sync:
            # If this was a rebase onto new base, update the stack base
            if new_base:
                set_stack_base(current_sync, new_base)
            state.mark_completed(current_sync)

    # Continue with remaining branches
    for branch in state.get_remaining_branches():
        if new_base:
            old_base = get_stack_base(branch)  # May be None for non-stacked
            if not rebase_onto_new_base(branch, new_base, old_base, state, git_root):
                sys.exit(1)
        else:
            if not sync_single_branch(branch, state, git_root):
                sys.exit(1)

    original = state.get_original_branch()
    state.cleanup()
    if original:
        git('checkout', original)
    print("Sync complete.")


def cmd_abort(git_root: Path, state: SyncState) -> None:
    """Abort current rebase, continue with remaining branches."""
    if not state.in_progress():
        print("No sync operation in progress.")
        sys.exit(1)

    # Abort current rebase if in progress
    if is_rebase_in_progress(git_root):
        print("Aborting current rebase...")
        git('rebase', '--abort', check=False)

    # Mark current branch as completed (skipped)
    current_sync = state.get_current_sync_branch()
    if current_sync:
        print(f"Skipping '{current_sync}'...")
        state.mark_completed(current_sync)

    # Continue with remaining branches
    remaining = state.get_remaining_branches()
    if not remaining:
        original = state.get_original_branch()
        state.cleanup()
        if original:
            git('checkout', original)
        print("Sync aborted. No remaining branches.")
    else:
        print("Continuing with remaining branches...")
        for branch in remaining:
            if not sync_single_branch(branch, state, git_root):
                sys.exit(1)

        original = state.get_original_branch()
        state.cleanup()
        if original:
            git('checkout', original)
        print("Sync complete (with some branches skipped).")


